{
  "name": "cricket-oracle",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:reset && next dev",
    "dev:plain": "next dev",
    "dev:port3001": "next dev -p 3001",
    "dev:reset": "for /f \"tokens=5\" %a in ('netstat -ano ^| findstr :3000 ^| findstr LISTENING') do taskkill /PID %a /F >nul 2>nul & powershell -NoProfile -Command \"Remove-Item -Path '.next' -Recurse -Force -ErrorAction SilentlyContinue; exit 0\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "import:cricsheet": "tsx scripts/importCricsheetJson.ts",
    "import:bulk:ipl": "tsx scripts/bulkImportCricsheet.ts ../ipl_json IPL",
    "import:bulk:t20i": "tsx scripts/bulkImportCricsheet.ts ../t20s_json T20I",
    "import:meta:ipl": "tsx scripts/bulkImportMetadata.ts ../ipl_json ipl",
    "import:meta:t20i": "tsx scripts/bulkImportMetadata.ts ../t20s_json t20i",
    "export:training": "tsx scripts/exportTrainingData.ts",
    "export:v4": "tsx scripts/exportTrainingRowsV4.ts",
    "export:v42:stratified": "tsx scripts/exportTrainingRowsV4.ts --featureVersion v42 --sampling stratified --out training/training_rows_v42_stratified.jsonl",
    "export:v43:stratified": "tsx scripts/exportTrainingRowsV4.ts --featureVersion v43 --sampling stratified --out training/training_rows_v43_stratified.jsonl",
    "export:v5:recent": "tsx scripts/exportTrainingRowsV4.ts --featureVersion v43 --sampling stratified --fromYear 2021 --out training/training_rows_v5_recent.jsonl",
    "build:delivery-tables": "tsx scripts/buildDeliveryTables.ts --fromYear 2021",
    "predict:match": "tsx scripts/predictImportedMatch.ts",
    "predict:all": "tsx scripts/predictAllImportedMatches.ts",
    "backtest:edge-v1": "tsx scripts/backtestEdgeV1.ts",
    "backfill:calibrated": "tsx scripts/backfillCalibratedV3.ts",
    "test:calibration": "tsx scripts/testCalibration.ts",
    "eval:v3v4": "tsx scripts/evaluateV3V4Quick.ts",
    "eval:v4:balanced": "tsx scripts/evaluateBalancedVsUnbalanced.ts",
    "eval:v4:sampling": "tsx scripts/evaluateSamplingSweep.ts",
    "eval:compare:v3v4": "tsx scripts/evalCompareV3VsV4.ts",
    "train:v4logreg": "tsx scripts/trainV4LogReg.ts --data training/training_rows_v4.jsonl",
    "train:v41logreg": "tsx scripts/trainV4LogReg.ts --featureVersion v41 --data training/training_rows_v41.jsonl",
    "train:v42logreg": "tsx scripts/trainV4LogReg.ts --featureVersion v42 --data training/training_rows_v42_stratified.jsonl",
    "train:v43logreg": "tsx scripts/trainV4LogReg.ts --featureVersion v43 --data training/training_rows_v43_stratified.jsonl",
    "train:v5lgbm": "\"C:/Users/rex4/AppData/Local/Programs/Python/Python312/python.exe\" scripts/trainLightGBM.py",
    "train:v5lgbm:recent": "\"C:/Users/rex4/AppData/Local/Programs/Python/Python312/python.exe\" scripts/trainLightGBM.py --data training/training_rows_v5_recent.jsonl --out lib/model/artifacts/v5_lgbm_recent.json",
    "train:v42:best": "tsx scripts/trainV4LogReg.ts --featureVersion v42 --data training/training_rows_v42_stratified.jsonl --l2 1e-9 --lr 0.008 --epochs 12 --useV42SampleWeights true",
    "train:tempcal:v42": "tsx scripts/trainTempCalibration.ts --data training/training_rows_v42_stratified.jsonl --model lib/model/artifacts/v42_logreg.json --out lib/model/artifacts/v42_temp_calibration.json --seed 42",
    "sweep:v42": "tsx scripts/sweepV42Hyperparams.ts",
    "sanity:orientation": "tsx scripts/sanityOrientation.ts --data training/training_rows_v43_stratified.jsonl --model lib/model/artifacts/v43_logreg.json",
    "predict:imported:v4logreg": "tsx scripts/predictImportedMatch.ts --modelVersion v4-logreg",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@prisma/client": "^5.22.0",
    "lightningcss": "^1.31.1",
    "next": "16.1.6",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.7.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
