// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id               String    @id @default(cuid())
  teamA            String
  teamB            String
  createdAt        DateTime  @default(now())

  // Cricsheet import fields
  source           String?   // e.g. "cricsheet"
  sourceMatchId    String?   // e.g. filename "335982"
  matchDate        DateTime?
  venue            String?
  city             String?
  teamAName        String?   // store info.teams[0] for mapping
  teamBName        String?   // store info.teams[1] for mapping
  winnerTeam       String?   // "A" | "B" | null
  tossWinnerTeam   String?   // "A" | "B" | null
  tossDecision     String?   // "bat" | "field"

  snapshots        MatchStateSnapshot[]
  matchPlayers     MatchPlayer[]
  ballEvents       BallEvent[]
  ballPredictions  BallPrediction[]
  liveCursors      LiveCursor[]
  liveBallEvents   LiveBallEvent[]
  liveInningsStates LiveInningsState[]
  marketEvents     MarketEvent[]
  edgeSignals      EdgeSignal[]

  @@unique([source, sourceMatchId])
  @@map("matches")
}

model Player {
  id          String    @id @default(cuid())
  name        String
  externalId  String?   // e.g. cricsheet registry id
  createdAt   DateTime  @default(now())

  matchPlayers MatchPlayer[]
  ballEvents   BallEvent[] @relation("Striker")
  ballEventsNS BallEvent[] @relation("NonStriker")
  ballEventsBowler BallEvent[] @relation("Bowler")

  @@unique([externalId])
  @@map("players")
}

model MatchPlayer {
  id        String    @id @default(cuid())
  matchId   String
  match     Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team      String    // "A" | "B"
  createdAt DateTime  @default(now())

  @@unique([matchId, playerId])
  @@index([matchId])
  @@map("match_players")
}

model BallEvent {
  id                String    @id @default(cuid())
  matchId           String
  match             Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  innings           Int       // 1 or 2
  over              Int       // 0-19
  ballInOver        Int       // 1-6 (plus extras)
  legalBallNumber   Int?      // 1-120 per innings; null for illegal deliveries
  battingTeam       String    // "A" | "B"
  
  strikerId         String
  striker           Player    @relation("Striker", fields: [strikerId], references: [id], onDelete: Restrict)
  nonStrikerId      String
  nonStriker        Player    @relation("NonStriker", fields: [nonStrikerId], references: [id], onDelete: Restrict)
  bowlerId          String
  bowler            Player    @relation("Bowler", fields: [bowlerId], references: [id], onDelete: Restrict)
  
  runsBat           Int
  runsExtras        Int
  runsTotal         Int
  extrasJson        Json?     // store original extras object
  isWide            Boolean   @default(false)
  isNoBall          Boolean   @default(false)
  isWicket          Boolean   @default(false)
  wicketJson        Json?     // store wickets array
  
  createdAt         DateTime  @default(now())

  @@index([matchId, innings, over, ballInOver])
  @@index([matchId, innings, legalBallNumber])
  @@map("ball_events")
}

model MatchStateSnapshot {
  id            String    @id @default(cuid())
  matchId       String
  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  
  innings       Int
  runs          Int
  wickets       Int
  balls         Int
  targetRuns    Int?
  runsAfter6    Int?
  runsAfter10   Int?
  runsAfter12   Int?
  teamFours     Int?
  teamSixes     Int?
  matchFours    Int?
  matchSixes    Int?

  predictions    Prediction[]

  @@index([matchId])
  @@map("match_state_snapshots")
}

model Prediction {
  id            String    @id @default(cuid())
  snapshotId    String
  snapshot      MatchStateSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  modelVersion  String
  winProb       Float
  createdAt     DateTime  @default(now())

  @@unique([snapshotId, modelVersion])
  @@map("predictions")
}

model BallPrediction {
  id                String    @id @default(cuid())
  matchId           String
  match             Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  innings           Int
  legalBallNumber   Int
  modelVersion      String    // e.g. "v3-lgbm", "v1", "v0"
  teamAWinProb      Float     // probability Team A wins (0.0 - 1.0)
  
  featuresJson      Json?     // optional: store the feature row used for debugging
  createdAt         DateTime  @default(now())

  @@unique([matchId, innings, legalBallNumber, modelVersion])
  @@index([matchId, modelVersion])
  @@map("ball_predictions")
}

model LiveCursor {
  id          String    @id @default(cuid())
  matchId     String    @unique
  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  provider    String    // provider name (e.g. "cricsheet-replay")
  cursor      String?   // last processed cursor (provider-specific)
  updatedAt   DateTime  @updatedAt

  @@index([matchId, provider])
  @@map("live_cursors")
}

model LiveBallEvent {
  id                String    @id @default(cuid())
  matchId           String
  match             Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  provider          String
  providerEventId   String    // stable unique ID from provider
  
  innings           Int
  over              Int
  ballInOver        Int
  battingTeam       String    // "A" | "B"
  
  striker           String
  nonStriker        String
  bowler            String
  
  runsBat           Int
  runsExtras        Int
  runsTotal         Int
  extrasJson        Json?
  wicketsJson       Json?
  
  isWide            Boolean   @default(false)
  isNoBall          Boolean   @default(false)
  isLegal           Boolean   @default(true)
  
  occurredAt        DateTime?
  createdAt         DateTime  @default(now())

  @@unique([provider, providerEventId])
  @@index([matchId, innings, over, ballInOver])
  @@map("live_ball_events")
}

model LiveInningsState {
  id          String    @id @default(cuid())
  matchId     String
  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)

  innings     Int
  runs        Int       @default(0)
  wickets     Int       @default(0)
  balls       Int       @default(0)
  targetRuns  Int?
  updatedAt   DateTime  @updatedAt

  @@unique([matchId, innings])
  @@index([matchId])
  @@map("live_innings_states")
}

model Market {
  id            String         @id @default(cuid())
  name          String         @unique  // e.g. "rollbit", "polymarket"
  createdAt     DateTime       @default(now())

  marketEvents  MarketEvent[]

  @@map("markets")
}

model MarketEvent {
  id                    String      @id @default(cuid())
  matchId               String
  match                 Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  marketId              String
  market                Market      @relation(fields: [marketId], references: [id], onDelete: Cascade)
  
  externalEventId       String      // market's unique identifier for this event
  selectionTeamAName    String      // team name as provided by market (for audit)
  selectionTeamBName    String
  status                String?     // e.g. "open", "closed", "settled"
  
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  oddsTicks             OddsTick[]
  edgeSignals           EdgeSignal[]

  @@unique([marketId, externalEventId])
  @@index([matchId])
  @@map("market_events")
}

model OddsTick {
  id                String      @id @default(cuid())
  marketEventId     String
  marketEvent       MarketEvent @relation(fields: [marketEventId], references: [id], onDelete: Cascade)
  
  observedAt        DateTime    // when odds were observed
  side              String      // "A" or "B"
  oddsDecimal       Float       // decimal odds (e.g. 2.5)
  impliedProbRaw    Float       // 1/oddsDecimal (includes overround)
  
  sourceJson        Json?       // raw JSON from provider for debugging
  createdAt         DateTime    @default(now())

  @@index([marketEventId, observedAt])
  @@index([side])
  @@map("odds_ticks")
}

model EdgeSignal {
  id                String      @id @default(cuid())
  matchId           String
  match             Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  marketEventId     String
  marketEvent       MarketEvent @relation(fields: [marketEventId], references: [id], onDelete: Cascade)
  
  modelVersion      String      // e.g. "v3-lgbm", "v1"
  observedAt        DateTime    // when this signal was computed
  
  teamAWinProb      Float       // model's prediction for Team A win
  marketProbA       Float       // market's fair probability for Team A (vig removed)
  edgeA             Float       // teamAWinProb - marketProbA (positive = model favors A)
  
  overround         Float?      // total overround (probA_raw + probB_raw - 1)
  notes             String?     // e.g. "one-sided market", "stale prediction"
  
  createdAt         DateTime    @default(now())

  @@index([matchId, observedAt])
  @@index([edgeA])
  @@index([observedAt])
  @@map("edge_signals")
}


